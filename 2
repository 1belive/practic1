Визуализация (Текстовое описание структуры BPMN):
graph LR
    subgraph Пул: Туроператор (Система)
        A[Начало: Поиск Отеля] --> B{Запрос данных};
        B --> C1(Запрос Цен у Поставщиков $P_{Base}$);
        B --> C2(Запрос Цен у Конкурентов $P_{Comp}$);
        C1 & C2 --> D{Применение Правил Ценообразования};
        D --> E{Конкурент > 10% лучше?};
        
        E -- Да --> F[Скорректировать $P_{Base}$];
        E -- Нет --> G[Применить Стандартную Наценку];
        
        F --> H(Расчет $P_{Dynamic}$ и Проверка Маржи);
        G --> H;
        
        H --> I[Отобразить $P_{Dynamic}$ Клиенту];
        I --> J[Клиент Выбирает Отель];
        
        J --> K(Финальное Бронирование у Поставщика);
        K --> Z[Конец: Бронирование Завершено];
    end
    
    subgraph Пул: Внешние Системы
        C1 --> P1[Поставщик Отелей/GDS];
        C2 --> P2[Система Мониторинга Конкурентов];
        P1 --> C1;
        P2 --> C2;
        K --> P1;
    end
